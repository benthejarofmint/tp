@startuml AddRecurringSequenceDiagram
skinparam sequenceArrowThickness 2
skinparam roundcorner 5
skinparam sequenceParticipant none

actor User
participant ":Ui" as Ui
participant ":Parser" as Parser
participant ":AddRecurringCommand" as AddRec
participant ":RecurringTransactionList" as RecList

User -> Ui : enter "add food/10 desc/lunch rec/daily"
activate Ui

Ui -> Parser : parse("add food/10 desc/lunch rec/daily")
activate Parser

Parser -> Parser : parseAddCommand("food/10 desc/lunch rec/daily")
activate Parser #LightGray
note right of Parser : Detects rec/ suffix;\nextracts Frequency.DAILY
Parser --> Parser : AddRecurringCommand
deactivate Parser

Parser --> Ui : AddRecurringCommand
deactivate Parser

Ui -> AddRec : execute(list, budget, ui)
activate AddRec

AddRec -> AddRec : validate category
activate AddRec #LightGray
note right of AddRec : Checks Income.VALID_CATEGORIES,\nExpense.VALID_CATEGORIES,\nand custom categories
AddRec --> AddRec
deactivate AddRec

alt invalid category
    AddRec -> Ui : showMessage("Invalid category ...")
    activate Ui #LightGray
    Ui --> AddRec
    deactivate Ui
else valid category
    create ":RecurringTransaction" as RT
    AddRec -> RT : <<create>>(category, amount, description, frequency, startDate)
    activate RT
    RT --> AddRec
    deactivate RT

    AddRec -> RecList : add(rt)
    activate RecList
    RecList --> AddRec
    deactivate RecList

    AddRec -> Ui : showMessage("Added recurring: ...")
    activate Ui #LightGray
    Ui --> AddRec
    deactivate Ui
end

deactivate AddRec
deactivate Ui
@enduml

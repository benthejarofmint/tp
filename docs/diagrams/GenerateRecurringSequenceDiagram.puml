@startuml GenerateRecurringSequenceDiagram
skinparam sequenceArrowThickness 2
skinparam roundcorner 5
skinparam sequenceParticipant none

actor User
participant ":Ui" as Ui
participant ":Parser" as Parser
participant ":GenerateRecurringCommand" as GenRec
participant ":RecurringTransactionList" as RecList
participant ":RecurringTransaction" as RT
participant ":TransactionList" as TList

User -> Ui : enter "gen-rec"
activate Ui

Ui -> Parser : parse("gen-rec")
activate Parser
Parser --> Ui : GenerateRecurringCommand
deactivate Parser

Ui -> GenRec : execute(list, budget, ui)
activate GenRec

loop for each template in recurringList
    GenRec -> RecList : get(i)
    activate RecList
    RecList --> GenRec : rt
    deactivate RecList

    GenRec -> GenRec : getNextDate(rt)
    activate GenRec #LightGray
    note right of GenRec : Returns startDate if lastGeneratedDate\nis null; else frequency.next(lastGeneratedDate)
    GenRec --> GenRec : nextDate : LocalDate
    deactivate GenRec

    loop while nextDate <= today
        GenRec -> GenRec : createTransaction(rt, nextDate)
        activate GenRec #LightGray
        note right of GenRec : Creates Income or Expense\nbased on rt.isIncome()
        GenRec --> GenRec : t : Transaction
        deactivate GenRec

        GenRec -> TList : add(t)
        activate TList
        TList --> GenRec
        deactivate TList

        GenRec -> RT : setLastGeneratedDate(nextDate)
        activate RT
        RT --> GenRec
        deactivate RT

        GenRec -> GenRec : nextDate = frequency.next(nextDate)
        activate GenRec #LightGray
        GenRec --> GenRec
        deactivate GenRec
    end

    opt templateCount > 0
        GenRec -> Ui : showMessage("Generated N transaction(s) from: ...")
        activate Ui #LightGray
        Ui --> GenRec
        deactivate Ui
    end
end

opt no transactions generated and recurringList not empty
    GenRec -> Ui : showMessage("No recurring transactions are due.")
    activate Ui #LightGray
    Ui --> GenRec
    deactivate Ui
end

deactivate GenRec
deactivate Ui
@enduml
